{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default",
      "description": "Configure the portable core, tests, headless runner, AI battle runner, and replay tools.",
      "binaryDir": "${sourceDir}/build/default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "MK_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "headless",
      "displayName": "Headless",
      "description": "Configure the portable core, tests, and headless runner.",
      "binaryDir": "${sourceDir}/build/headless",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "MK_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "strict",
      "displayName": "Strict",
      "description": "Configure a headless warning-clean build for CI-style checks.",
      "binaryDir": "${sourceDir}/build/strict",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "MK_BUILD_TESTS": "ON",
        "MK_WARNINGS_AS_ERRORS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "headless",
      "configurePreset": "headless"
    },
    {
      "name": "strict",
      "configurePreset": "strict"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "headless",
      "configurePreset": "headless",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "strict",
      "configurePreset": "strict",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
